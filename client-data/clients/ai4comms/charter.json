{
  "meta": {
    "tier": "producer",
    "displayName": "AI4comms",
    "tagline": "Kies voor AI als partner, niet als vervanger",
    "tagline_en": "Choose AI as a partner, not a replacement",
    "industry": "Communications / AI enablement",
    "audience": "Dutch-speaking communications professionals",
    "locale": [
      "nl-NL",
      "en"
    ],
    "direction": "Practical AI enablement partner",
    "archetype": {
      "primary": "Sage",
      "secondary": "Caregiver"
    },
    "protection_class": "protected",
    "protected_assets": { "heading_font": true, "body_font": false, "primary_color": true, "accent_color": true, "motif_family": true }
  },
  "colors": {
    "primary": "#15311A",
    "secondary": "#214C28",
    "accent": "#9EC187",
    "background": "#FFFFFF",
    "backgroundAlt": "#F8FAFC",
    "text": "#1F1F1F",
    "textLight": "#4E4E4E",
    "success": "#3B7A4E",
    "warning": "#C89B3E",
    "error": "#B85648"
  },
  "fonts": {
    "heading": {
      "family": "Montserrat",
      "fallback": "\"Helvetica Neue\", Arial, sans-serif",
      "weight": "700"
    },
    "body": {
      "family": "Montserrat",
      "fallback": "\"Helvetica Neue\", Arial, sans-serif",
      "weight": "400"
    },
    "mono": {
      "family": "JetBrains Mono",
      "fallback": "\"SFMono-Regular\", Consolas, monospace",
      "weight": "500"
    }
  },
  "logo": {
    "primary": "logos/ai4comms-logo-primary.svg",
    "png": "logos/ai4comms-logo-primary.png",
    "favicon_192": "logos/ai4comms-favicon-192.png",
    "favicon_180": "logos/ai4comms-favicon-180.png",
    "maxWidth": "180pt",
    "maxHeight": "60pt",
    "sizing": "contain",
    "_note": "Live deployed brand has only one logo variant (green wordmark on light backgrounds). White-on-dark variant, icon-only mark, and square mark variants are NOT deployed and have been intentionally omitted. Reintroduce only when client commissions them."
  },
  "images": {
    "catalog": [
      {
        "file": "images/comms-env-08-bGo01h57aCE--16x9-textsafe.jpg",
        "description": "Dark architectural communications environment with strong lines and controlled contrast",
        "roles": [
          "cover",
          "divider"
        ]
      },
      {
        "file": "images/data-tex-05-ETiSF2VSRTQ--16x9-textsafe.jpg",
        "description": "Abstract data texture with a restrained technical feel for section transitions",
        "roles": [
          "divider"
        ]
      },
      {
        "file": "images/signal-03-nwNjeZ0WA6w--16x9-textsafe.jpg",
        "description": "Signal-oriented visual used for closing moments and strategic emphasis",
        "roles": [
          "closing"
        ]
      }
    ],
    "overlay": {
      "color": "primary",
      "opacity": 0.55
    },
    "logoVariantOnImage": "primary",
    "_note": "Overlay is canopy green at 55% (guidelines: --overlay-canopy-55), applied only when text must sit on the image. Only one logo variant exists (green wordmark, see logo._note) — do NOT place the logo on overlaid/dark imagery; if a page pairs logo and image, put the logo on an unoverlaid light region."
  },
  "document": {
    "margins": {
      "top": "1in",
      "bottom": "1in",
      "left": "1in",
      "right": "1in"
    },
    "header": {
      "content": "{{company.name}}",
      "logo": true
    },
    "footer": {
      "content": "Confidential",
      "pageNumbers": true
    },
    "headingColor": "primary",
    "tableHeaderColor": "primary"
  },
  "presentation": {
    "slideMargin": "40pt",
    "titleMargin": "30pt",
    "contentMargin": "20pt",
    "aspectRatio": "16:9",
    "defaultTheme": "light"
  },
  "video": {
    "resolution": "1920x1080",
    "fps": 30
  },
  "website": {
    "archetype": "sage",
    "aesthetic": "minimalist",
    "layout": {
      "density": "balanced",
      "symmetry": "symmetric",
      "flowDirection": "linear",
      "heroStyle": "typographic",
      "gridSystem": "12col-centered",
      "maxWidth": "1320px",
      "sectionSpacing": "generous",
      "sectionDividers": "thin-line",
      "footerStyle": "minimal",
      "whitespaceStrategy": "breathing"
    },
    "texture": {
      "backgroundTreatment": "gradient-mesh",
      "surfaceFinish": "matte",
      "borderStyle": "thin-line",
      "shadowDepth": "subtle",
      "cornerRadius": "slight",
      "overlayStyle": "gradient",
      "patternDensity": "none"
    },
    "typography": {
      "headingStyle": "tight-sans",
      "headingScale": 1.15,
      "bodyLineHeight": 1.7,
      "letterSpacing": "normal",
      "textTransform": "uppercase-labels",
      "pullQuoteStyle": "bordered-left",
      "listStyle": "standard"
    },
    "motion": {
      "intensity": "subtle",
      "revealStyle": "fade",
      "scrollBehavior": "smooth",
      "hoverBehavior": "color-shift",
      "transitionSpeed": "relaxed",
      "loadingAnimation": "stagger-fade",
      "cursorStyle": "default",
      "interactionMode": "hover-focus",
      "ambientScope": "none",
      "reducedMotionPolicy": "auto-disable-decorative"
    },
    "components": {
      "navigation": "sticky-minimal",
      "cards": "outlined",
      "buttons": "rounded",
      "forms": "minimal-underline",
      "imagePresentation": "rectangular",
      "testimonials": "simple-quote",
      "ctaStyle": "inline",
      "socialProof": "logo-strip",
      "codeBlocks": "default"
    },
    "colorApplication": {
      "darkSections": false,
      "darkSectionFrequency": 0,
      "accentUsage": "sparring",
      "gradientDirection": "diagonal",
      "colorBlockSections": false,
      "imageOverlayBehavior": "brand-tint"
    },
    "pages": {
      "home": {
        "enabled": true,
        "sections": [
          {
            "type": "hero",
            "variant": "typographic-gradient"
          },
          {
            "type": "mission",
            "variant": "centered-statement"
          },
          {
            "type": "services",
            "variant": "alternating-rows"
          },
          {
            "type": "approach",
            "variant": "numbered-steps"
          },
          {
            "type": "faq",
            "variant": "accordion"
          },
          {
            "type": "cta",
            "variant": "minimal"
          }
        ]
      },
      "waarom-ai4comms": {
        "enabled": true,
        "_note": "Live page: /waarom-ai4comms/"
      },
      "expertise": {
        "enabled": true,
        "_note": "Live page: /expertise/"
      },
      "over-ons": {
        "enabled": true,
        "_note": "Live page: /over-ons/"
      },
      "afspraak": {
        "enabled": true,
        "layout": "mailto-or-calendar",
        "_note": "Live page: /afspraak/"
      }
    },
    "deployment": {
      "platform": "github-pages",
      "theme": "bureau-peppr-child",
      "analytics": "none",
      "contactForm": "mailto"
    },
    "_note": "The `website` block describes the schema-valid Astro target the org's website-builder would produce. The deployed site is WordPress/Divi (theme: bureau-peppr-child) and is outside this schema's enum space; see .build-history/BUILD_LOG.md and guidelines.md for the deployed truth."
  },
  "formatting": {
    "headingThreshold": 24,
    "accentCycleColors": [
      "accent",
      "secondary",
      "primary"
    ],
    "autoContrastText": true
  },
  "plotly": {
    "categoricalPalette": [
      "#15311A",
      "#9EC187",
      "#3B7A4E",
      "#C89B3E",
      "#82AE68",
      "#4E4E4E"
    ],
    "defaultHeight": 500,
    "titleFontSize": 18,
    "axisFontSize": 12,
    "legendFontSize": 11,
    "margins": {
      "top": 80,
      "bottom": 70,
      "left": 60,
      "right": 50
    },
    "gridColor": "#ECECEC",
    "secondaryTextColor": "#4E4E4E"
  },
  "templates": {
    "docx": {
      "default": "templates/docx/default.docx",
      "letterhead": "templates/docx/letterhead.docx"
    },
    "html": {
      "business-cards": "business-cards/review/business-cards.html",
      "email-signature": "templates/html/email-signature.html"
    }
  },
  "_audit": {
    "source": "_build/brand-intelligence/ai4comms/audit.md",
    "date": "2026-05-18",
    "decision": "Realigned to deployed identity at ai4-comms.com (option B from audit). Aspirational dark-mode 'Signal Authority' brand archived to .build-history/aspirational-2026-04-05/.",
    "mode": "Refresh (Mode C)"
  }
}
