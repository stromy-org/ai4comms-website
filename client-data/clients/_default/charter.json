{
  "meta": {
    "tier": "output",
    "displayName": "Default",
    "industry": "General"
  },
  "colors": {
    "primary": "#1f2937",
    "secondary": "#6b7280",
    "accent": "#3b82f6",
    "background": "#FFFFFF",
    "backgroundAlt": "#f8f9fa",
    "text": "#1f2937",
    "textLight": "#6b7280",
    "success": "#28A745",
    "warning": "#FFC107",
    "error": "#DC3545"
  },
  "fonts": {
    "heading": { "family": "Arial", "fallback": "Helvetica, sans-serif", "weight": "bold" },
    "body": { "family": "Verdana", "fallback": "Arial, sans-serif", "weight": "normal" },
    "mono": { "family": "Courier New", "fallback": "monospace", "weight": "normal" }
  },
  "logo": { "primary": "", "white": "", "maxWidth": "120pt", "maxHeight": "50pt", "sizing": "contain" },
  "document": {
    "margins": { "top": "1in", "bottom": "1in", "left": "1in", "right": "1in" },
    "header": { "content": "", "logo": false },
    "footer": { "content": "", "pageNumbers": true },
    "headingColor": "primary",
    "tableHeaderColor": "accent"
  },
  "formatting": {
    "headingThreshold": 24,
    "accentCycleColors": ["accent", "secondary", "primary"],
    "autoContrastText": true
  },
  "website": {
    "archetype": "sage",
    "aesthetic": "minimalist",
    "layout": {
      "density": "balanced",
      "symmetry": "symmetric",
      "heroStyle": "minimal-text",
      "gridSystem": "12col-centered",
      "sectionSpacing": "balanced",
      "footerStyle": "minimal"
    },
    "texture": {
      "backgroundTreatment": "solid",
      "surfaceFinish": "matte",
      "borderStyle": "thin-line",
      "shadowDepth": "subtle",
      "cornerRadius": "slight"
    },
    "typography": {
      "headingStyle": "standard",
      "headingScale": 1.0,
      "bodyLineHeight": 1.6,
      "letterSpacing": "normal"
    },
    "motion": {
      "intensity": "subtle",
      "revealStyle": "fade",
      "hoverBehavior": "lift",
      "transitionSpeed": "relaxed"
    },
    "components": {
      "navigation": "sticky-minimal",
      "cards": "bordered",
      "buttons": "rounded"
    },
    "colorApplication": {
      "darkSections": false,
      "accentUsage": "balanced"
    },
    "pages": {
      "home": { "enabled": true },
      "about": { "enabled": true },
      "contact": { "enabled": true }
    },
    "deployment": {
      "platform": "github-pages",
      "analytics": "none",
      "contactForm": "mailto"
    }
  },
  "plotly": {
    "categoricalPalette": ["#3b82f6", "#10b981", "#f59e0b", "#ef4444", "#8b5cf6"],
    "defaultHeight": 500,
    "titleFontSize": 18,
    "axisFontSize": 12,
    "legendFontSize": 11,
    "margins": { "top": 80, "bottom": 70, "left": 60, "right": 50 },
    "baseTemplate": "plotly_white",
    "gridColor": "#e5e7eb",
    "secondaryTextColor": "#6b7280",
    "bar": {
      "markerLineWidth": 1
    },
    "line": { "width": 2, "markerSize": 7 },
    "scatter": { "markerSize": 8, "markerLineWidth": 0 },
    "pie": {
      "hole": 0.0,
      "textfontSize": 13,
      "markerLineColor": "white",
      "markerLineWidth": 1
    },
    "sentiment": {
      "positiveColor": "#28A745",
      "neutralColor": "#7f7f7f",
      "negativeColor": "#DC3545"
    }
  }
}
