{
  "meta": {
    "tier": "output",
    "displayName": "SEC Newgate",
    "industry": "Communications / PR"
  },
  "colors": {
    "primary": "#15193E",
    "secondary": "#4a4e6b",
    "accent": "#FF8201",
    "background": "#FFFFFF",
    "backgroundAlt": "#F4F6F8",
    "text": "#15193E",
    "textLight": "#4a4e6b",
    "success": "#2ca02c",
    "warning": "#FFC107",
    "error": "#d62728"
  },
  "fonts": {
    "heading": { "family": "Times New Roman", "fallback": "Times, serif", "weight": "bold" },
    "body": { "family": "Times New Roman", "fallback": "Times, serif", "weight": "normal" },
    "mono": { "family": "Courier New", "fallback": "monospace", "weight": "normal" }
  },
  "logo": { "primary": "", "white": "", "maxWidth": "120pt", "maxHeight": "50pt", "sizing": "contain" },
  "document": {
    "margins": { "top": "1in", "bottom": "1in", "left": "1in", "right": "1in" },
    "header": { "content": "", "logo": false },
    "footer": { "content": "Confidential", "pageNumbers": true },
    "headingColor": "primary",
    "tableHeaderColor": "primary"
  },
  "formatting": {
    "headingThreshold": 24,
    "accentCycleColors": ["accent", "secondary", "primary"],
    "autoContrastText": true
  },
  "plotly": {
    "categoricalPalette": ["#15193E", "#FF8201", "#4a4e6b", "#ffa040", "#0d0f26"],
    "defaultHeight": 600,
    "titleFontSize": 20,
    "axisFontSize": 12,
    "legendFontSize": 12,
    "margins": { "top": 100, "bottom": 80, "left": 60, "right": 60 },
    "secondaryTextColor": "#4a4e6b",
    "gridColor": "#e5e7eb",
    "line": { "width": 3, "markerSize": 8 },
    "scatter": { "markerSize": 10 },
    "pie": { "textfontSize": 14 }
  }
}
