---
import PageLayout from "../layouts/PageLayout.astro";
import HomeHero from "../components/sections/HomeHero.astro";
import ValueProposition from "../components/sections/ValueProposition.astro";
import ServicesPreview from "../components/sections/ServicesPreview.astro";
import CaseStudyShowcase from "../components/sections/CaseStudyShowcase.astro";
import MinimalCta from "../components/sections/MinimalCta.astro";
import { copy } from "../data/content/copy";
---

<PageLayout
  title={copy.home.seoTitle}
  description={copy.home.seoDesc}
  pathname="/"
>
  <HomeHero />
  <ValueProposition />
  <ServicesPreview />
  <CaseStudyShowcase />
  <MinimalCta />
</PageLayout>
