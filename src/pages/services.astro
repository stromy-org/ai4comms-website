---
import PageLayout from "../layouts/PageLayout.astro";
import { services } from "../data/company";
import { copy } from "../data/content/copy";
---

<PageLayout
  title={copy.services.seoTitle}
  description={copy.services.seoDesc}
  pathname="/services"
>
  <section class="page-hero">
    <div class="shell page-hero__inner">
      <div class="eyebrow">{copy.services.eyebrow}</div>
      <h1 class="page-title">{copy.services.title}</h1>
      <p class="page-intro">
        {copy.services.intro}
      </p>
    </div>
  </section>

  <section class="section section--paper">
    <div class="shell">
      <div class="grid-2">
        {services.map((service) => (
          <article class="surface-card service-card">
            <div class="eyebrow">{service.typicalDuration}</div>
            <h2>{service.name}</h2>
            <p>{service.description}</p>
            <ul class="list-reset service-card__list">
              {service.deliverables.map((deliverable) => <li>{deliverable}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .service-card {
    padding: 24px;
  }

  .service-card h2 {
    margin: 14px 0 0;
    font-family: var(--brand-font-heading);
    font-size: 2rem;
    letter-spacing: -0.03em;
    color: var(--text-dark);
  }

  .service-card p {
    color: rgba(19, 32, 24, 0.74);
    line-height: 1.72;
  }

  .service-card__list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 18px;
  }

  .service-card__list li {
    padding: 10px 12px;
    border: 1px solid rgba(19, 32, 24, 0.12);
    border-radius: 999px;
    color: rgba(19, 32, 24, 0.72);
    font-size: 0.95rem;
  }
</style>
