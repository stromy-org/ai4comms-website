---
import PageLayout from "../layouts/PageLayout.astro";
import { copy } from "../data/content/copy";
---

<PageLayout
  title={copy.notFound.seoTitle}
  description={copy.notFound.seoDesc}
  pathname="/404"
  noindex={true}
>
  <section class="page-hero">
    <div class="shell page-hero__inner">
      <div class="eyebrow">{copy.notFound.eyebrow}</div>
      <h1 class="page-title">{copy.notFound.title}</h1>
      <p class="page-intro">
        {copy.notFound.intro}
      </p>
      <div class="button-row">
        <a class="button button--primary" href="/">{copy.notFound.backHome}</a>
        <a class="button button--secondary" href="/services">{copy.notFound.viewServices}</a>
      </div>
    </div>
  </section>
</PageLayout>
