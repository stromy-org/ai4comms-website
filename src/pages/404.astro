---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout
  title="Page not found"
  description="The page you were looking for does not exist."
  pathname="/404"
>
  <section class="page-hero">
    <div class="shell page-hero__inner">
      <div class="eyebrow">404</div>
      <h1 class="page-title">Nothing useful lives at this route.</h1>
      <p class="page-intro">
        Return to the homepage or go directly to services, case studies, or contact.
      </p>
      <div class="button-row">
        <a class="button button--primary" href="/">Back to home</a>
        <a class="button button--secondary" href="/services">View services</a>
      </div>
    </div>
  </section>
</PageLayout>
