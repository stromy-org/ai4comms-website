---
import { company } from "../../data/company";
import { copy } from "../../data/content/copy";

const value = copy.home.value;
---

<section class="section section--paper reveal-on-scroll" data-reveal>
  <div class="shell">
    <div class="eyebrow">{value.eyebrow}</div>
    <h2 class="section-title">{value.title}</h2>
    <p class="page-intro">
      {value.intro}
    </p>

    <div class="value-list">
      {company.differentiators.map((item) => (
        <article class="value-item">
          <div class="value-item__number">{item.number}</div>
          <div>
            <h3>{item.title}</h3>
            <p>{item.body}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .value-list {
    display: grid;
    gap: 18px;
    margin-top: 2.5rem;
  }

  .value-item {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 18px;
    padding: 22px 0;
    border-top: 1px solid rgba(19, 32, 24, 0.12);
  }

  .value-item:last-child {
    border-bottom: 1px solid rgba(19, 32, 24, 0.12);
  }

  .value-item__number {
    font-family: var(--brand-font-mono);
    color: var(--brand-secondary);
    font-size: 0.85rem;
    letter-spacing: 0.18em;
  }

  .value-item h3 {
    margin: 0;
    font-family: var(--brand-font-heading);
    font-size: 1.8rem;
    letter-spacing: -0.03em;
  }

  .value-item p {
    margin: 10px 0 0;
    color: rgba(19, 32, 24, 0.72);
    line-height: 1.72;
    max-width: 58ch;
  }

  @media (max-width: 720px) {
    .value-item {
      grid-template-columns: 1fr;
    }
  }
</style>
