---
import { company } from "../../data/company";
import { navigation, site } from "../../data/site";
import logoWhite from "../../brand/logos/ai4comms-logo-white.svg";
---

<footer class="site-footer">
  <div class="shell site-footer__grid">
    <div class="site-footer__brand">
      <img src={logoWhite.src} alt="AI4comms" />
      <p>{company.description}</p>
      <p class="site-footer__note">{site.footerNote}</p>
    </div>

    <div class="site-footer__links">
      <div>
        <h2>Navigation</h2>
        <ul class="list-reset">
          {navigation.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <h2>Contact</h2>
        <ul class="list-reset">
          <li>{company.office.label}</li>
          <li>{company.contact.email ?? "Email address pending confirmation"}</li>
          <li>{company.contact.phone ?? "Phone number pending confirmation"}</li>
        </ul>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 2rem 0 3.5rem;
    border-top: 1px solid rgba(184, 216, 138, 0.14);
    background: linear-gradient(180deg, rgba(10, 16, 13, 0), rgba(10, 16, 13, 0.72));
  }

  .site-footer__grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 28px;
    padding-top: 2rem;
  }

  .site-footer__brand img {
    width: 148px;
  }

  .site-footer__brand p {
    max-width: 54ch;
    color: rgba(244, 246, 241, 0.72);
    line-height: 1.72;
  }

  .site-footer__note {
    color: rgba(146, 156, 142, 0.94);
    font-size: 0.95rem;
  }

  .site-footer__links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 20px;
  }

  .site-footer__links h2 {
    margin: 0 0 0.9rem;
    font-family: var(--brand-font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brand-accent);
  }

  .site-footer__links li {
    margin-bottom: 0.7rem;
    color: rgba(244, 246, 241, 0.72);
  }

  .site-footer__links a {
    text-decoration: none;
  }

  @media (max-width: 900px) {
    .site-footer__grid,
    .site-footer__links {
      grid-template-columns: 1fr;
    }
  }
</style>
