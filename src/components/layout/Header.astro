---
import { navigation } from "../../data/site";
import logoWhite from "../../brand/logos/ai4comms-logo-white.svg";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
---

<header class="site-header" data-site-header>
  <div class="shell site-header__inner">
    <a class="site-header__brand" href="/">
      <img src={logoWhite.src} alt="AI4comms" />
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      {navigation.map((item) => (
        <a href={item.href} class:list={{ "is-active": pathname === item.href }}>
          {item.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 18px 0 0;
    transition: padding 220ms ease;
  }

  .site-header.is-solid {
    padding-top: 10px;
  }

  .site-header__inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding: 14px 18px;
    border: 1px solid rgba(184, 216, 138, 0.08);
    border-radius: 999px;
    background: rgba(10, 17, 13, 0.18);
    backdrop-filter: blur(12px);
    transition: background-color 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
  }

  .site-header.is-solid .site-header__inner {
    background: rgba(10, 17, 13, 0.82);
    border-color: rgba(184, 216, 138, 0.16);
    box-shadow: 0 16px 30px rgba(2, 6, 4, 0.24);
  }

  .site-header__brand img {
    width: 142px;
  }

  .site-header__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 18px;
  }

  .site-header__nav a {
    text-decoration: none;
    color: rgba(244, 246, 241, 0.76);
    font-size: 0.9rem;
    transition: color 180ms ease;
  }

  .site-header__nav a.is-active,
  .site-header__nav a:hover {
    color: var(--brand-accent);
  }

  @media (max-width: 820px) {
    .site-header__inner {
      border-radius: 28px;
      align-items: flex-start;
      flex-direction: column;
      padding: 16px 18px;
    }

    .site-header__nav {
      justify-content: flex-start;
      gap: 14px;
    }

    .site-header__nav a {
      font-size: 0.84rem;
    }
  }
</style>
