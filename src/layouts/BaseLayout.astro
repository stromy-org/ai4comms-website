---
import "../styles/global.css";
import { company } from "../data/company";
import { site } from "../data/site";
import Seo from "../components/seo/Seo.astro";
import { identitySchema, webSiteSchema } from "../lib/seo";

interface Props {
  title?: string;
  description?: string;
  pathname?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  pathname = "/",
  image,
  noindex = false,
} = Astro.props;

// Identity + WebSite emitted once, on the homepage. Enrich the Organization
// with the richer company facts (legalName, slogan) the data file carries —
// preserving the previous Organization JSON-LD while deduplicating it to one
// page instead of every page.
const isHome = pathname === "/";
const homeJsonLd = isHome
  ? [
      {
        ...identitySchema(site),
        legalName: company.legalName,
        description: company.description,
        slogan: company.tagline,
      },
      webSiteSchema(site),
    ]
  : [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0C1410" />

    <Seo
      title={title}
      description={description}
      image={image}
      canonical={pathname}
      noindex={noindex}
      jsonLd={homeJsonLd}
    />
  </head>
  <body>
    <slot />
    <script is:inline src="/ambient.js"></script>
  </body>
</html>
