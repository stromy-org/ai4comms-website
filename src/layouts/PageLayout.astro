---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";

interface Props {
  title: string;
  description: string;
  pathname: string;
  image?: string;
  noindex?: boolean;
}

const { title, description, pathname, image, noindex } = Astro.props;
---

<BaseLayout title={title} description={description} pathname={pathname} image={image} noindex={noindex}>
  <Header pathname={pathname} />
  <main>
    <slot />
  </main>
  <Footer />
</BaseLayout>
